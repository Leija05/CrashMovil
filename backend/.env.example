MONGO_URL=mongodb://localhost:27017
DB_NAME=crash_database
JWT_SECRET=change-this-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Emergency AI diagnosis
EMERGENT_LLM_KEY=

# WhatsApp webhook validation token (same value configured in Meta Developers)
WEBHOOK_VERIFY_TOKEN=mi_token_secreto_2026_crash

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v25.0
# Usa template cuando el mensaje de texto falle por ventana de 24h (error 131047)
WHATSAPP_TEMPLATE_NAME=hello_world
WHATSAPP_TEMPLATE_LANGUAGE=en_US
WHATSAPP_TEMPLATE_FALLBACK_ON_24H=true

# Twilio (optional fallback integration)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
